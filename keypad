```

  </div>
</div>

<script>
  const correctPin = "1234"; // change this
  let input = "";

  const dotsContainer = document.getElementById("dots");
  const message = document.getElementById("message");

  function updateDots() {
    dotsContainer.innerHTML = "";
    for (let i = 0; i < 4; i++) {
      const dot = document.createElement("div");
      dot.classList.add("dot");
      if (i < input.length) dot.classList.add("filled");
      dotsContainer.appendChild(dot);
    }
  }

  function press(num) {
    if (input.length < 4) {
      input += num;
      updateDots();

      if (input.length === 4) {
        setTimeout(checkPin, 200);
      }
    }
  }

  function clearPin() {
    input = "";
    message.textContent = "";
    updateDots();
  }

  function checkPin() {
    if (input === correctPin) {
      message.textContent = "Access Granted";
      message.style.color = "#00d084";
    } else {
      message.textContent = "Wrong PIN";
      message.style.color = "#ff4d4d";
    }

    setTimeout(() => {
      clearPin();
    }, 1000);
  }

  // initialize
  updateDots();
</script>

</body>
</html>
