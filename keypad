.container {
  background: #222;
  padding: 20px;
  border-radius: 12px;
  text-align: center;
  color: #fff;
  box-shadow: 0 8px 20px rgba(0,0,0,0.3);
}

.dots {
  display: flex;
  justify-content: center;
  margin-bottom: 15px;
  gap: 10px;
}

.dot {
  width: 15px;
  height: 15px;
  border-radius: 50%;
  background: #555;
}

.dot.filled {
  background: #00d084;
}

.message {
  height: 20px;
  margin-bottom: 10px;
  font-size: 0.9rem;
}

.buttons {
  display: grid;
  grid-template-columns: repeat(3, 60px);
  gap: 10px;
  justify-content: center;
}

button {
  height: 60px;
  font-size: 1.2rem;
  border: none;
  border-radius: 8px;
  background: #444;
  color: #fff;
  cursor: pointer;
}

button:hover {
  background: #666;
}

.wide {
  grid-column: span 3;
  background: #e74c3c;
}
