<body>

<div class="container">
  <div class="dots" id="dots"></div>
  <div class="message" id="message"></div>

  <div class="buttons">
    <button onclick="press(1)">1</button>
    <button onclick="press(2)">2</button>
    <button onclick="press(3)">3</button>

